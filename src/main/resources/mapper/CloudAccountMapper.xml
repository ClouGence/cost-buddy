<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.costbuddy.mapper.CloudAccountMapper">

    <resultMap id="CloudAccountResultMap" type="com.costbuddy.domain.CloudAccountDO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="provider" property="provider"/>
        <result column="access_key_id" property="accessKeyId"/>
        <result column="access_key_secret" property="accessKeySecret"/>
        <result column="bill_owner_id" property="billOwnerId"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="BaseColumnList">id, name, provider, access_key_id, access_key_secret, bill_owner_id, enabled, created_at, updated_at</sql>

    <select id="selectById" resultMap="CloudAccountResultMap">
        SELECT <include refid="BaseColumnList"/> FROM cloud_account WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="CloudAccountResultMap">
        SELECT <include refid="BaseColumnList"/> FROM cloud_account ORDER BY id DESC
    </select>

    <insert id="insert" parameterType="com.costbuddy.domain.CloudAccountDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO cloud_account (name, provider, access_key_id, access_key_secret, bill_owner_id, enabled)
        VALUES (#{name}, #{provider}, #{accessKeyId}, #{accessKeySecret}, #{billOwnerId}, #{enabled})
    </insert>

    <update id="update" parameterType="com.costbuddy.domain.CloudAccountDO">
        UPDATE cloud_account
        SET name = #{name},
            provider = #{provider},
            access_key_id = #{accessKeyId},
            access_key_secret = #{accessKeySecret},
            bill_owner_id = #{billOwnerId},
            enabled = #{enabled}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM cloud_account WHERE id = #{id}
    </delete>
</mapper>
